<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[BizHawk*]*</Exclude>
          <ExcludeByFile>**/Program.cs,**/MainForm.cs,**/MainForm.Designer.cs,**/GamePanel.cs,**/EmulationThread.cs,**/SteamManager.cs,**/D3DOverlayHook.cs,**/EmulatorHost.cs,**/NeshimFileProvider.cs,**/NullOpenGLProvider.cs,**/MainMenuMusic.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
